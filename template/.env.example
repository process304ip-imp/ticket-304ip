# ===================================================
# CRM 304IP Ticket — Environment Variables Template
# ===================================================
# Copy ไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ห้าม commit .env ขึ้น git เด็ดขาด!
# ===================================================

# --- Supabase (Frontend - ใส่ VITE_ prefix) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# --- Cloudflare R2 (Server-side only - ห้ามใส่ VITE_) ---
# ใช้ใน Netlify Functions เท่านั้น
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=crm-304ip-attachments
R2_PUBLIC_DOMAIN=https://pub-xxxx.r2.dev
